# ============================================================
# GreenPurse — Environment Variables
# Copy this to apps/web-greenpurse/.env.local
# ============================================================

# ─── API ──────────────────────────────────────────────
# Point to your deployed API. In dev: http://localhost:4000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ─── Maps ─────────────────────────────────────────────
# Get a free token at https://mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── App URL ─────────────────────────────────────────
# The URL where this frontend is hosted (used for OAuth redirects, deep links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Environment ──────────────────────────────────────
NODE_ENV=development
PORT=3000