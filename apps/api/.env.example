# ============================================================
# AI-SUCE API — Environment Variables
# Copy this to apps/api/.env before running in any environment
# ============================================================

# ─── Application ──────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── JWT Authentication ───────────────────────────────
# REQUIRED in production — app refuses to start if missing or placeholder
JWT_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── CORS ─────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# ─── Database (PostgreSQL) ─────────────────────────────
# Option A: Full connection string (recommended — takes precedence)
DATABASE_URL=

# Option B: Individual variables (used when DATABASE_URL is empty)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aisuce
DB_USER=postgres
DB_PASS=postgres
DB_SSL=false

# ─── Redis ───────────────────────────────────────────
# Option A: Full URL (recommended — takes precedence)
REDIS_URL=

# Option B: Individual variables (used when REDIS_URL is empty)
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Payment Gateway (Paystack) ───────────────────────
# Development: use test keys from https://dashboard.paystack.com
# Production:  use live keys (sk_live_...)
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# ─── File Storage ─────────────────────────────────────
# Options: local | cloudinary | s3
STORAGE_PROVIDER=local

# Local storage (default — no cloud config needed)
UPLOAD_DIR=./uploads
APP_URL=http://localhost:4000

# Cloudinary (required when STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AWS S3 (required when STORAGE_PROVIDER=s3)
AWS_REGION=eu-west-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Platform Business Config (optional overrides) ───
# PLATFORM_FEE_PERCENT=10
# MIN_WITHDRAWAL=1000
# MIN_DEPOSIT=100
# FREE_DELIVERY_THRESHOLD=5000
# DELIVERY_BASE_FEE=500
# REFERRAL_BONUS=500
# SUPPORT_EMAIL=support@aisuce.com
# PLATFORM_NAME=AgriChain AI

# ─── External Data APIs ───────────────────────────────
# OPENWEATHER_API_KEY=
# COMMODITY_PRICE_API_URL=https://api.example.com/v1
# TERMII_API_KEY=

# ─── AI Service URL ───────────────────────────────────
# AI_SERVICE_URL=http://localhost:8001

# ─── Deployment Security ───────────────────────────────
# ALLOWED_IPS=          # Comma-separated IPs allowed to access admin endpoints
# BANNED_IPS=           # Comma-separated IPs to block entirely
# RATE_LIMIT_STRICT=   # Set true to enable stricter rate limits on all endpoints
# LOG_LEVEL=error      # Logging verbosity: error | warn | log | debug | verbose